---
oracle_hostname: ""
oracle_port: 1521
oracle_dsn: null
oracle_service_name: null
oracle_username: null
oracle_password: null
oracle_home: "/oracle/u01/product/23.26.0.0"
oracle_sid: TEST26C1

oracle_pdb_service_name: TPDB

mode: "sysdba"

#
running_on_server: true
running_on_server_crs: true

running_on_db_asm: true
running_on_db_fs: false
running_on_cdb: true
running_on_pdb: true
running_on_client: false
running_on_adb: false
running_on_xe: false

#
oracle_wallet_location: /home/oracle/wallet

# ASM path prefix for PDB datafiles: +<DISKGROUP>/<DB_UNIQUE_NAME>
# Replace +XDATA with your diskgroup (e.g. +DATA, +XDATA, +DGDATA) and
# TEST26C_1 with your DB unique name (check: SELECT db_unique_name FROM v$database)
oracle_datadir: "+XDATA/TEST26C_1"
